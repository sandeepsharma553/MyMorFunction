rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // 🔒 Signed employment contracts (pay + PII): NO client access. Created/read ONLY by
    // Cloud Functions via the Admin SDK (which bypass Storage rules and re-check
    // owner/storeAdmin). Must be paired with the guard on the catch-all below.
    match /restaurantGroups/{groupId}/contracts/{rest=**} {
      allow read, write: if false;
    }

    // Catch-all — UNCHANGED, except it must NOT also grant on the contracts subtree
    // (Storage ORs overlapping matches, so a blanket allow would re-open the deny above).
    match /{allPaths=**} {
      allow read, write: if request.auth != null
        && !(allPaths.size() >= 3 && allPaths[0] == 'restaurantGroups' && allPaths[2] == 'contracts');
    }

    match /chat_media/{groupId}/{fileName} {
     allow write: if request.auth != null;
     allow read: if request.auth != null;
     }

    match /community_chat_media/{fileName} {
     allow write: if request.auth != null;
     allow read: if request.auth != null;
     }

    match /rgMessages/{groupId}/{file=**} {
      allow read, write: if request.auth != null;
    }

    match /restaurantGroups/{groupId}/staffCerts/{p=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|application/pdf');
    }

    match /restaurantGroups/{groupId}/staffDocs/{p=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 15 * 1024 * 1024
        && request.resource.contentType.matches('image/.*|application/pdf');
    }
  }
}